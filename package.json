{
  "name": "career-os",
  "version": "0.1.0",
  "private": true,
  "packageManager": "npm@10.8.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @career-os/web",
    "build": "npm run build --workspaces --if-present",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prisma:generate": "prisma generate",
    "lint": "eslint . --ext .ts,.tsx",
    "commit:guard": "npm run typecheck && npm test && npm run lint"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "bullmq": "^5.8.2",
    "ioredis": "^5.4.1",
    "next": "^14.2.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^8.57.0",
    "prisma": "^5.16.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.3",
    "vitest": "^1.6.0"
  }
}
