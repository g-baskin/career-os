generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum DomainStatus {
  placeholder
  partial
  implemented
  deprecated
  disabled
}

enum ApplicationPacketStatus {
  not_started
  ready_to_generate
  generated
  awaiting_review
  ready_to_apply
  submitted
  followup_due
  closed
}

enum JobSegmentValue {
  REMOTE_COMMERCIAL
  HYBRID_COMMERCIAL
  ONSITE_COMMERCIAL
  CONTRACT
  CLEARANCE_GOVERNMENT
  PUBLIC_TRUST
  SECRET
  TOP_SECRET
  TS_SCI
  POLYGRAPH
  CLEARANCE_ELIGIBLE
  UNKNOWN_CLEARANCE_RISK
  LOW_FIT
  ARCHIVED_REJECTED
}

model User {
  id           String          @id @default(cuid())
  email        String          @unique
  name         String?
  createdAt    DateTime        @default(now())
  profile      UserProfile?
  preferences  UserPreference?
  events       Event[]
  applications Application[]

  @@index([createdAt])
}

model UserProfile {
  id          String   @id @default(cuid())
  userId      String   @unique
  headline    String?
  skills      String[]
  targetRoles String[]
  user        User     @relation(fields: [userId], references: [id])
}

model UserPreference {
  id                 String  @id @default(cuid())
  userId             String  @unique
  remoteFirst        Boolean @default(true)
  commercialFirst    Boolean @default(true)
  clearanceSeparated Boolean @default(true)
  user               User    @relation(fields: [userId], references: [id])
}

model DomainRegistry {
  id           String               @id @default(cuid())
  name         String
  slug         String               @unique
  manager      String
  status       DomainStatus         @default(placeholder)
  version      String
  capabilities CapabilityRegistry[]
  workers      WorkerRegistry[]
  tools        ToolRegistry[]
}

model CapabilityRegistry {
  id          String         @id @default(cuid())
  domainId    String
  name        String
  commands    String[]
  events      String[]
  permissions String[]
  domain      DomainRegistry @relation(fields: [domainId], references: [id])

  @@index([domainId])
}

model WorkerRegistry {
  id       String         @id @default(cuid())
  domainId String
  name     String
  status   DomainStatus   @default(placeholder)
  domain   DomainRegistry @relation(fields: [domainId], references: [id])

  @@index([domainId])
}

model ToolRegistry {
  id       String         @id @default(cuid())
  domainId String
  name     String
  status   DomainStatus   @default(placeholder)
  domain   DomainRegistry @relation(fields: [domainId], references: [id])

  @@index([domainId])
}

model Event {
  id            String   @id @default(cuid())
  eventType     String
  entityType    String
  entityId      String
  domain        String
  manager       String?
  capability    String?
  worker        String?
  userId        String?
  payload       Json?
  evidence      Json?
  confidence    Float?
  modelUsed     String?
  promptVersion String?
  createdAt     DateTime @default(now())
  user          User?    @relation(fields: [userId], references: [id])

  @@index([eventType])
  @@index([entityType])
  @@index([entityId])
  @@index([eventType, entityType, entityId])
  @@index([domain])
  @@index([userId])
  @@index([createdAt])
}

model StateProjection {
  id             String   @id @default(cuid())
  userId         String?
  projectionType String
  entityType     String
  entityId       String
  data           Json
  sourceEventId  String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([projectionType, entityType, entityId])
  @@index([userId])
  @@index([projectionType])
  @@index([entityType])
  @@index([entityId])
  @@index([updatedAt])
}

model Snapshot {
  id           String   @id @default(cuid())
  userId       String?
  entityType   String
  entityId     String
  snapshotType String
  data         Json
  checksum     String?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([entityType, entityId])
  @@index([snapshotType])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String?
  action     String
  entityType String?
  entityId   String?
  payload    Json?
  createdAt  DateTime @default(now())

  @@index([actorId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model ApprovalRequest {
  id              String    @id @default(cuid())
  userId          String
  commandId       String
  commandType     String
  permission      String
  entityType      String?
  entityId        String?
  status          String    @default("pending")
  riskLevel       String
  reason          String
  requestPayload     Json?
  decisionPayload    Json?
  replayStatus       String    @default("not_started")
  replayedCommandId  String?
  replayResult       Json?
  replayError        Json?
  replayAttemptCount Int       @default(0)
  requestedBy        String
  requestedAt        DateTime  @default(now())
  decidedAt          DateTime?
  expiresAt          DateTime?
  replayedAt         DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  @@index([userId])
  @@index([commandId])
  @@index([commandType])
  @@index([permission])
  @@index([status])
  @@index([replayStatus])
  @@index([replayedCommandId])
  @@index([entityType, entityId])
  @@index([createdAt])
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
}

model Company {
  id                 String              @id @default(cuid())
  name               String
  website            String?
  industry           String?
  createdAt          DateTime            @default(now())
  sources            CompanySource[]
  aliases            CompanyAlias[]
  technologies       CompanyTechnology[]
  watchlists         CompanyWatchlist[]
  careerPages        CareerPage[]
  atsProfiles        AtsProfile[]
  jobs               Job[]
  people             Person[]
  applicationPackets ApplicationPacket[]

  @@index([name])
  @@index([createdAt])
}

model CompanySource {
  id        String  @id @default(cuid())
  companyId String
  source    String
  url       String?
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
}

model CompanyAlias {
  id        String  @id @default(cuid())
  companyId String
  alias     String
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([alias])
}

model CompanyTechnology {
  id         String  @id @default(cuid())
  companyId  String
  technology String
  company    Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([technology])
}

model CompanyWatchlist {
  id        String  @id @default(cuid())
  companyId String
  userId    String
  priority  Int     @default(0)
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([userId])
}

model CareerPage {
  id        String  @id @default(cuid())
  companyId String
  url       String
  status    String  @default("unknown")
  company   Company @relation(fields: [companyId], references: [id])

  @@index([companyId])
  @@index([status])
}

model AtsProfile {
  id         String        @id @default(cuid())
  companyId  String
  atsName    String
  confidence Float?
  company    Company       @relation(fields: [companyId], references: [id])
  playbooks  AtsPlaybook[]

  @@index([companyId])
  @@index([atsName])
}

model AtsPlaybook {
  id           String     @id @default(cuid())
  atsProfileId String
  name         String
  details      Json?
  atsProfile   AtsProfile @relation(fields: [atsProfileId], references: [id])

  @@index([atsProfileId])
}

model Job {
  id                    String                          @id @default(cuid())
  companyId             String?
  title                 String
  location              String?
  description           String?
  url                   String?
  status                String                          @default("discovered")
  createdAt             DateTime                        @default(now())
  company               Company?                        @relation(fields: [companyId], references: [id])
  snapshots             JobSnapshot[]
  sources               JobSource[]
  skills                JobSkill[]
  certifications        JobCertification[]
  clearanceFlags        JobClearanceFlag[]
  remoteClassifications JobRemoteClassification[]
  salaryRanges          JobSalaryRange[]
  segments              JobSegment[]
  fitScores             JobFitScore[]
  difficultyScores      JobApplicationDifficultyScore[]
  applications          Application[]
  applicationPackets    ApplicationPacket[]

  @@index([companyId])
  @@index([status])
  @@index([createdAt])
}

model JobSnapshot {
  id         String   @id @default(cuid())
  jobId      String
  content    Json
  capturedAt DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([capturedAt])
}

model JobSource {
  id     String  @id @default(cuid())
  jobId  String
  source String
  url    String?
  job    Job     @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([source])
}

model JobSkill {
  id    String @id @default(cuid())
  jobId String
  skill String
  job   Job    @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([skill])
}

model JobCertification {
  id            String  @id @default(cuid())
  jobId         String
  certification String
  required      Boolean @default(false)
  job           Job     @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([certification])
}

model JobClearanceFlag {
  id       String  @id @default(cuid())
  jobId    String
  flag     String
  evidence String?
  job      Job     @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([flag])
}

model JobRemoteClassification {
  id             String @id @default(cuid())
  jobId          String
  classification String
  confidence     Float?
  job            Job    @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([classification])
}

model JobSalaryRange {
  id       String @id @default(cuid())
  jobId    String
  min      Int?
  max      Int?
  currency String @default("USD")
  job      Job    @relation(fields: [jobId], references: [id])

  @@index([jobId])
}

model JobSegment {
  id      String          @id @default(cuid())
  jobId   String
  segment JobSegmentValue
  reason  String?
  job     Job             @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([segment])
}

model JobDuplicate {
  id             String @id @default(cuid())
  canonicalJobId String
  duplicateJobId String
  confidence     Float?

  @@index([canonicalJobId])
  @@index([duplicateJobId])
}

model JobFitScore {
  id       String @id @default(cuid())
  jobId    String
  score    Int
  evidence Json?
  job      Job    @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([score])
}

model JobApplicationDifficultyScore {
  id       String @id @default(cuid())
  jobId    String
  score    Int
  evidence Json?
  job      Job    @relation(fields: [jobId], references: [id])

  @@index([jobId])
  @@index([score])
}

model Application {
  id        String                     @id @default(cuid())
  userId    String
  jobId     String
  status    String                     @default("ready_to_apply")
  createdAt DateTime                   @default(now())
  user      User                       @relation(fields: [userId], references: [id])
  job       Job                        @relation(fields: [jobId], references: [id])
  packets   ApplicationPacket[]
  events    ApplicationEvent[]
  questions ApplicationQuestion[]
  documents ApplicationDocument[]
  history   ApplicationStatusHistory[]

  @@index([userId])
  @@index([jobId])
  @@index([status])
  @@index([createdAt])
}

model ApplicationPacket {
  id                          String                  @id @default(cuid())
  applicationId               String?
  jobId                       String?
  companyId                   String?
  personId                    String?
  fitScoreSummary             Json?
  resumePlaceholder           String?
  coverLetterPlaceholder      String?
  recruiterMessagePlaceholder String?
  notes                       String[]
  status                      ApplicationPacketStatus @default(not_started)
  nextAction                  String?
  createdAt                   DateTime                @default(now())
  updatedAt                   DateTime                @updatedAt
  application                 Application?            @relation(fields: [applicationId], references: [id])
  job                         Job?                    @relation(fields: [jobId], references: [id])
  company                     Company?                @relation(fields: [companyId], references: [id])
  person                      Person?                 @relation(fields: [personId], references: [id])

  @@index([applicationId])
  @@index([jobId])
  @@index([companyId])
  @@index([personId])
  @@index([status])
  @@index([createdAt])
  @@index([updatedAt])
}

model ApplicationEvent {
  id            String      @id @default(cuid())
  applicationId String
  eventType     String
  payload       Json?
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([eventType])
  @@index([createdAt])
}

model ApplicationQuestion {
  id            String              @id @default(cuid())
  applicationId String
  question      String
  sensitive     Boolean             @default(false)
  application   Application         @relation(fields: [applicationId], references: [id])
  answers       ApplicationAnswer[]

  @@index([applicationId])
}

model ApplicationAnswer {
  id         String              @id @default(cuid())
  questionId String
  answer     String
  approved   Boolean             @default(false)
  question   ApplicationQuestion @relation(fields: [questionId], references: [id])

  @@index([questionId])
  @@index([approved])
}

model ApplicationDocument {
  id            String      @id @default(cuid())
  applicationId String
  documentType  String
  url           String?
  application   Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([documentType])
}

model ApplicationStatusHistory {
  id            String      @id @default(cuid())
  applicationId String
  status        String
  createdAt     DateTime    @default(now())
  application   Application @relation(fields: [applicationId], references: [id])

  @@index([applicationId])
  @@index([status])
  @@index([createdAt])
}

model MasterResume {
  id       String          @id @default(cuid())
  userId   String
  content  Json
  versions ResumeVersion[]

  @@index([userId])
}

model ResumeVersion {
  id             String       @id @default(cuid())
  masterResumeId String
  jobId          String?
  companyId      String?
  content        Json
  templateId     String?
  masterResume   MasterResume @relation(fields: [masterResumeId], references: [id])

  @@index([masterResumeId])
  @@index([jobId])
  @@index([companyId])
}

model ResumeTemplate {
  id           String @id @default(cuid())
  name         String
  templateType String
  content      Json?
}

model CoverLetter {
  id            String  @id @default(cuid())
  applicationId String?
  content       String
  status        String  @default("draft")

  @@index([applicationId])
  @@index([status])
}

model RecruiterMessage {
  id        String   @id @default(cuid())
  personId  String?
  content   String
  createdAt DateTime @default(now())

  @@index([personId])
  @@index([createdAt])
}

model DocumentExport {
  id           String   @id @default(cuid())
  documentType String
  format       String
  url          String?
  createdAt    DateTime @default(now())

  @@index([documentType])
  @@index([createdAt])
}

model DocumentVersion {
  id           String   @id @default(cuid())
  documentType String
  documentId   String
  content      Json
  createdAt    DateTime @default(now())

  @@index([documentType, documentId])
  @@index([createdAt])
}

model DocumentMetadata {
  id           String @id @default(cuid())
  documentType String
  documentId   String
  metadata     Json

  @@index([documentType, documentId])
}

model Person {
  id                 String                @id @default(cuid())
  name               String
  normalizedName     String?
  linkedinUrl        String?
  currentCompanyId   String?
  companyName        String?
  agency             String?
  relationshipScore  Int                   @default(0)
  relevanceScore     Int                   @default(0)
  responsivenessScore Int                  @default(0)
  trustScore         Int                   @default(0)
  lastContactDate    DateTime?
  lastContactedAt    DateTime?
  nextFollowUpDate   DateTime?
  nextFollowupAt     DateTime?
  currentCompany     Company?              @relation(fields: [currentCompanyId], references: [id])
  roles              PersonRole[]
  emails             PersonEmail[]
  phones             PersonPhoneNumber[]
  recruiterProfile   RecruiterProfile?
  hiringManagerProfile HiringManagerProfile?
  interviewerProfile InterviewerProfile?
  referralProfile    ReferralProfile?
  relationships      Relationship[]
  events             RelationshipEvent[]
  conversations      Conversation[]
  timelines          ContactTimeline[]
  applicationPackets ApplicationPacket[]

  @@index([currentCompanyId])
  @@index([normalizedName])
  @@index([companyName])
  @@index([relationshipScore])
  @@index([trustScore])
  @@index([responsivenessScore])
  @@index([lastContactedAt])
  @@index([nextFollowupAt])
}

model PersonRole {
  id        String    @id @default(cuid())
  personId  String
  role      String
  companyId String?
  startedAt DateTime?
  endedAt   DateTime?
  person    Person    @relation(fields: [personId], references: [id])

  @@index([personId])
  @@index([companyId])
  @@index([role])
}

model PersonEmail {
  id       String @id @default(cuid())
  personId String
  email    String @unique
  person   Person @relation(fields: [personId], references: [id])

  @@index([personId])
}

model PersonPhoneNumber {
  id       String @id @default(cuid())
  personId String
  phone    String
  person   Person @relation(fields: [personId], references: [id])

  @@index([personId])
  @@index([phone])
}

model RecruiterProfile {
  id               String @id @default(cuid())
  personId         String @unique
  jobsSent         Int    @default(0)
  relevantJobsSent Int    @default(0)
  person           Person @relation(fields: [personId], references: [id])
}

model HiringManagerProfile {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])
}

model InterviewerProfile {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])
}

model ReferralProfile {
  id       String @id @default(cuid())
  personId String @unique
  person   Person @relation(fields: [personId], references: [id])
}

model Relationship {
  id       String @id @default(cuid())
  personId String
  userId   String
  status   String
  person   Person @relation(fields: [personId], references: [id])

  @@index([personId])
  @@index([userId])
  @@index([status])
}

model RelationshipEvent {
  id        String   @id @default(cuid())
  personId  String
  eventType String
  payload   Json?
  createdAt DateTime @default(now())
  person    Person   @relation(fields: [personId], references: [id])

  @@index([personId])
  @@index([eventType])
  @@index([createdAt])
}

model Conversation {
  id       String                @id @default(cuid())
  personId String
  subject  String?
  person   Person                @relation(fields: [personId], references: [id])
  messages ConversationMessage[]

  @@index([personId])
}

model ConversationMessage {
  id             String       @id @default(cuid())
  conversationId String
  direction      String
  content        String
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}

model ContactTimeline {
  id        String   @id @default(cuid())
  personId  String
  eventType String
  summary   String
  createdAt DateTime @default(now())
  person    Person   @relation(fields: [personId], references: [id])

  @@index([personId])
  @@index([eventType])
  @@index([createdAt])
}

model EmailAccount {
  id       String @id @default(cuid())
  userId   String
  provider String
  email    String

  @@index([userId])
}

model EmailThread {
  id               String         @id @default(cuid())
  accountId        String
  providerThreadId String
  subject          String?
  messages         EmailMessage[]

  @@index([accountId])
  @@index([providerThreadId])
}

model EmailMessage {
  id              String                @id @default(cuid())
  threadId        String
  from            String
  to              String[]
  subject         String?
  body            String?
  receivedAt      DateTime?
  thread          EmailThread           @relation(fields: [threadId], references: [id])
  classifications EmailClassification[]
  attachments     EmailAttachment[]

  @@index([threadId])
  @@index([receivedAt])
}

model EmailClassification {
  id         String       @id @default(cuid())
  messageId  String
  category   String
  confidence Float?
  message    EmailMessage @relation(fields: [messageId], references: [id])

  @@index([messageId])
  @@index([category])
}

model EmailAttachment {
  id       String       @id @default(cuid())
  messageId String
  filename String
  mimeType String?
  url      String?
  message  EmailMessage @relation(fields: [messageId], references: [id])

  @@index([messageId])
}

model EmailDraft {
  id               String   @id @default(cuid())
  accountId        String
  to               String[]
  subject          String
  body             String
  approvalRequired Boolean  @default(true)

  @@index([accountId])
  @@index([approvalRequired])
}

model CalendarAccount {
  id       String @id @default(cuid())
  userId   String
  provider String
  email    String

  @@index([userId])
}

model CalendarEvent {
  id              String          @id @default(cuid())
  accountId       String
  providerEventId String
  title           String
  startsAt        DateTime
  endsAt          DateTime
  meetingLinks    MeetingLink[]
  interviewEvent  InterviewEvent?

  @@index([accountId])
  @@index([startsAt])
}

model InterviewEvent {
  id              String              @id @default(cuid())
  calendarEventId String              @unique
  companyId       String?
  jobId           String?
  stage           String?
  status          String              @default("scheduled")
  calendarEvent   CalendarEvent       @relation(fields: [calendarEventId], references: [id])
  attendees       InterviewAttendee[]

  @@index([companyId])
  @@index([jobId])
  @@index([status])
}

model MeetingLink {
  id              String        @id @default(cuid())
  calendarEventId String
  provider        String
  url             String
  calendarEvent   CalendarEvent @relation(fields: [calendarEventId], references: [id])

  @@index([calendarEventId])
}

model InterviewAttendee {
  id               String         @id @default(cuid())
  interviewEventId String
  personId         String?
  email            String?
  interviewEvent   InterviewEvent @relation(fields: [interviewEventId], references: [id])

  @@index([interviewEventId])
  @@index([personId])
}

model FollowupRule {
  id               String  @id @default(cuid())
  name             String
  delayDays        Int
  maxAttempts      Int
  approvalRequired Boolean @default(true)
}

model Followup {
  id            String          @id @default(cuid())
  personId      String?
  applicationId String?
  dueAt         DateTime
  status        String          @default("due")
  events        FollowupEvent[]

  @@index([personId])
  @@index([applicationId])
  @@index([dueAt])
  @@index([status])
}

model FollowupEvent {
  id         String   @id @default(cuid())
  followupId String
  eventType  String
  payload    Json?
  createdAt  DateTime @default(now())
  followup   Followup @relation(fields: [followupId], references: [id])

  @@index([followupId])
  @@index([eventType])
  @@index([createdAt])
}

model FollowupTemplate {
  id   String @id @default(cuid())
  name String
  body String
}

model SnoozeRule {
  id            String @id @default(cuid())
  name          String
  durationHours Int
}

model KnowledgeItem {
  id      String @id @default(cuid())
  title   String
  content Json
}

model MemoryItem {
  id      String @id @default(cuid())
  userId  String
  content Json

  @@index([userId])
}

model SkillGap {
  id       String @id @default(cuid())
  userId   String
  skill    String
  priority Int    @default(0)

  @@index([userId])
  @@index([skill])
}

model MarketMetric {
  id         String   @id @default(cuid())
  name       String
  value      Json
  capturedAt DateTime @default(now())

  @@index([name])
  @@index([capturedAt])
}

model LearningMetric {
  id     String @id @default(cuid())
  userId String
  metric String
  value  Json

  @@index([userId])
  @@index([metric])
}

model ReputationRecord {
  id     String @id @default(cuid())
  userId String
  source String
  value  Json

  @@index([userId])
  @@index([source])
}

model ReferralOpportunity {
  id        String @id @default(cuid())
  userId    String
  personId  String?
  companyId String?
  status    String

  @@index([userId])
  @@index([personId])
  @@index([companyId])
  @@index([status])
}

model OpportunityRecord {
  id      String @id @default(cuid())
  userId  String
  source  String
  payload Json

  @@index([userId])
  @@index([source])
}

model FinanceRecord {
  id         String @id @default(cuid())
  userId     String
  recordType String
  payload    Json

  @@index([userId])
  @@index([recordType])
}

model SalaryBenchmark {
  id       String @id @default(cuid())
  role     String
  location String?
  min      Int?
  max      Int?
  source   String

  @@index([role])
  @@index([location])
}

model OfferRecord {
  id            String @id @default(cuid())
  applicationId String?
  payload       Json
  status        String

  @@index([applicationId])
  @@index([status])
}

model ResearchNote {
  id      String @id @default(cuid())
  userId  String
  title   String
  content String

  @@index([userId])
}

model SimulationResult {
  id             String   @id @default(cuid())
  userId         String
  simulationType String
  result         Json
  createdAt      DateTime @default(now())

  @@index([userId])
  @@index([simulationType])
  @@index([createdAt])
}
